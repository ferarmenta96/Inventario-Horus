async function submitAddMaterial() {
  const tipo = document.getElementById('add-type').value;
  const nombre = document.getElementById('add-name').value.trim();
  const calibre = document.getElementById('add-calibre').value.trim();
  const dimensiones = document.getElementById('add-dimensiones').value.trim();
  const stock = parseInt(document.getElementById('add-stock').value) || 0;
  const minimo = parseInt(document.getElementById('add-minimo').value) || 5;
  const unidad = document.getElementById('add-unidad').value;

  if (!nombre) { showToast('Ingresa un nombre para el material', 'error'); return; }

  const material = { id: Date.now().toString(), tipo, nombre, calibre, dimensiones, stock, minimo, unidad };
  STATE.inventory.push(material);

  try {
    await callGAS('addMaterial', material);
    showToast('Material agregado ✓', 'success');
  } catch {
    showToast('Guardado localmente', '');
  }

  closeModal('modal-add');
  renderInventory();
  populateMaterialSelect();
  renderDashboard();

  // Clear
  ['add-name','add-calibre','add-dimensiones','add-stock','add-minimo'].forEach(id => {
    document.getElementById(id).value = '';
  });
}

