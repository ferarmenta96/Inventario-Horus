<script>
// ════════════════════════════════════════════
//  CONFIG & STATE
// ════════════════════════════════════════════
let CONFIG = {};
let STATE = {
  inventory: [],
  movements: [],
  currentFilter: 'todos',
  currentMovType: 'entrada',
};

// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
window.onload = () => {
  const saved = localStorage.getItem('horus_config');
  if (saved) {
    CONFIG = JSON.parse(saved);
    showApp();
  } else {
    document.getElementById('setup-screen').style.display = 'flex';
    document.getElementById('app').style.display = 'none';
  }
};

function saveConfig() {
  const sheetId = document.getElementById('cfg-sheet-id').value.trim();
  const gasUrl = document.getElementById('cfg-gas-url').value.trim();
  const openaiKey = document.getElementById('cfg-openai-key').value.trim();

  if (!gasUrl) { showToast('Ingresa la URL del Web App de Google Apps Script', 'error'); return; }
  if (!openaiKey) { showToast('Ingresa tu API Key de OpenAI', 'error'); return; }

  CONFIG = { sheetId, gasUrl, openaiKey };
  localStorage.setItem('horus_config', JSON.stringify(CONFIG));
  showApp();
}

function showApp() {
  document.getElementById('setup-screen').style.display = 'none';
  const app = document.getElementById('app');
  app.style.display = 'flex';
  app.style.flexDirection = 'column';

  const now = new Date();
  document.getElementById('dash-date').textContent =
    now.toLocaleDateString('es-MX', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

  loadData();
}

// ════════════════════════════════════════════
//  DATA LOADING (Google Apps Script → Sheets)
// ════════════════════════════════════════════
async function callGAS(action, payload = {}) {
  const url = CONFIG.gasUrl;
  const body = { action, ...payload };
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  });
  return res.json();
}

async function loadData() {
  try {
    const [invRes, movRes] = await Promise.all([
      callGAS('getInventory'),
      callGAS('getMovements', { limit: 50 }),
    ]);

    STATE.inventory = invRes.data || getSampleInventory();
    STATE.movements = movRes.data || getSampleMovements();
  } catch (e) {
    console.warn('GAS unavailable, using sample data:', e);
    STATE.inventory = getSampleInventory();
    STATE.movements = getSampleMovements();
  }

  renderDashboard();
  renderInventory();
  renderMovements();
  populateMaterialSelect();
}

async function syncSheets() {
  const dot = document.getElementById('sync-dot');
  const lbl = document.getElementById('sync-label');
  dot.classList.add('syncing');
  lbl.textContent = 'Sincronizando...';
  await loadData();
  dot.classList.remove('syncing');
  lbl.textContent = 'Sincronizado ✓';
  setTimeout(() => lbl.textContent = 'Sincronizar', 2000);
  showToast('Datos actualizados', 'success');
}

// ════════════════════════════════════════════
//  RENDER DASHBOARD
// ════════════════════════════════════════════
function renderDashboard() {
  const inv = STATE.inventory;
  const mov = STATE.movements;
  const thisMonth = new Date().getMonth();

  document.getElementById('stat-total').textContent = inv.length;

  const lowCount = inv.filter(i => i.stock <= i.minimo).length;
  document.getElementById('stat-low').textContent = lowCount;
  if (lowCount > 0) {
    document.getElementById('stat-low-card').classList.add('alert');
  }

  const movThisMonth = mov.filter(m => {
    try { return new Date(m.fecha).getMonth() === thisMonth; } catch { return true; }
  }).length;
  document.getElementById('stat-mov').textContent = movThisMonth;

  // Chart by type
  const types = ['Tubo','Lámina','Barra'];
  const counts = types.map(t => inv.filter(i => i.tipo === t).length);
  const max = Math.max(...counts, 1);
  const chartEl = document.getElementById('dash-chart');
  chartEl.innerHTML = types.map((t,i) => `
    <div class="chart-bar-wrap">
      <div class="chart-bar-label">${t}s</div>
      <div class="chart-bar-track">
        <div class="chart-bar-fill ${counts[i]/max < 0.2 ? 'low':''}" style="width:${Math.round(counts[i]/max*100)}%"></div>
      </div>
      <div class="chart-bar-val">${counts[i]}</div>
    </div>
  `).join('');

  // Recent activity
  const recent = [...mov].slice(0,6);
  const actEl = document.getElementById('activity-list');
  if (recent.length === 0) {
    actEl.innerHTML = `<div class="empty-state"><div class="empty-icon">📋</div><p>Sin movimientos aún</p></div>`;
    return;
  }
  actEl.innerHTML = recent.map(m => `
    <div class="activity-item">
      <div class="activity-icon ${m.tipo}">
        ${m.tipo === 'entrada' ? '⬆️' : '⬇️'}
      </div>
      <div class="activity-text">
        <div class="activity-name">${m.material}</div>
        <div class="activity-meta">${m.fecha} · ${m.ref || '—'}</div>
      </div>
      <div class="activity-qty ${m.tipo === 'salida' ? 'neg':''}">
        ${m.tipo === 'entrada' ? '+' : '-'}${m.cantidad}
      </div>
    </div>
  `).join('');
}

// ════════════════════════════════════════════
//  RENDER INVENTORY
// ════════════════════════════════════════════
let currentFilterType = 'todos';

function setFilter(type, btn) {
  currentFilterType = type;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filterInventory();
}

function filterInventory() {
  const search = document.getElementById('inv-search').value.toLowerCase();
  let items = STATE.inventory;

  if (currentFilterType === 'bajo') {
    items = items.filter(i => i.stock <= i.minimo);
  } else if (currentFilterType !== 'todos') {
    items = items.filter(i => i.tipo === currentFilterType);
  }

  if (search) {
    items = items.filter(i =>
      i.nombre.toLowerCase().includes(search) ||
      i.calibre.toLowerCase().includes(search) ||
      i.dimensiones.toLowerCase().includes(search)
    );
  }

  renderInventoryList(items);
}

function renderInventory() { filterInventory(); }

function renderInventoryList(items) {
  const el = document.getElementById('inventory-list');
  if (items.length === 0) {
    el.innerHTML = `<div class="empty-state"><div class="empty-icon">🗄️</div><p>Sin materiales en esta categoría</p></div>`;
    return;
  }

  const typeClass = { Tubo:'type-tubo', Lámina:'type-lamina', Barra:'type-barra' };
  const pct = i => Math.min(100, Math.round((i.stock / (i.minimo * 4 || 20)) * 100));

  el.innerHTML = items.map(item => `
    <div class="inv-card ${item.stock <= item.minimo ? 'stock-warning':''}">
      <div class="inv-card-header">
        <div class="inv-card-name">${item.nombre}</div>
        <span class="inv-card-type ${typeClass[item.tipo]||'type-tubo'}">${item.tipo}</span>
      </div>
      <div class="inv-card-specs">
        ${item.calibre ? `<span class="spec-tag">⚙️ ${item.calibre}</span>`:''}
        ${item.dimensiones ? `<span class="spec-tag">📐 ${item.dimensiones}</span>`:''}
        ${item.unidad ? `<span class="spec-tag">${item.unidad}</span>`:''}
      </div>
      <div class="inv-card-footer">
        <div class="inv-stock">
          <span class="inv-stock-num">${item.stock}</span>
          <span class="inv-stock-unit">${item.unidad||'pcs'}</span>
          ${item.stock <= item.minimo ? '<span style="color:var(--red);font-size:0.7rem;margin-left:0.35rem">⚠️ bajo</span>':''}
        </div>
        <div class="inv-actions">
          <button class="btn-sm" onclick="quickMove('${item.id}','entrada')">+</button>
          <button class="btn-sm danger" onclick="quickMove('${item.id}','salida')">−</button>
        </div>
      </div>
      <div class="stock-bar-mini">
        <div class="stock-bar-fill ${item.stock <= item.minimo ? 'low':''}" style="width:${pct(item)}%"></div>
      </div>
    </div>
  `).join('');
}

// ════════════════════════════════════════════
//  MOVEMENTS
// ════════════════════════════════════════════
function setMovType(type) {
  STATE.currentMovType = type;
  const btnE = document.getElementById('toggle-entrada');
  const btnS = document.getElementById('toggle-salida');
  if (type === 'entrada') {
    btnE.className = 'toggle-btn active-entrada';
    btnS.className = 'toggle-btn';
  } else {
    btnE.className = 'toggle-btn';
    btnS.className = 'toggle-btn active-salida';
  }
}

function populateMaterialSelect() {
  const sel = document.getElementById('mov-material');
  const byType = {};
  STATE.inventory.forEach(i => {
    if (!byType[i.tipo]) byType[i.tipo] = [];
    byType[i.tipo].push(i);
  });
  sel.innerHTML = '<option value="">— Seleccionar material —</option>';
  Object.entries(byType).forEach(([type, items]) => {
    const og = document.createElement('optgroup');
    og.label = type + 's';
    items.forEach(i => {
      const opt = document.createElement('option');
      opt.value = i.id;
      opt.textContent = `${i.nombre} · ${i.calibre} · ${i.dimensiones}`;
      og.appendChild(opt);
    });
    sel.appendChild(og);
  });
}

async function submitMovement() {
  const matId = document.getElementById('mov-material').value;
  const qty = parseInt(document.getElementById('mov-qty').value);
  const ref = document.getElementById('mov-ref').value;
  const note = document.getElementById('mov-note').value;

  if (!matId) { showToast('Selecciona un material', 'error'); return; }
  if (!qty || qty < 1) { showToast('Ingresa una cantidad válida', 'error'); return; }

  const mat = STATE.inventory.find(i => i.id === matId);
  if (!mat) return;

  if (STATE.currentMovType === 'salida' && qty > mat.stock) {
    showToast(`Stock insuficiente. Disponible: ${mat.stock} ${mat.unidad}`, 'error');
    return;
  }

  const mov = {
    id: Date.now().toString(),
    tipo: STATE.currentMovType,
    materialId: matId,
    material: mat.nombre,
    cantidad: qty,
    ref,
    nota: note,
    fecha: new Date().toLocaleDateString('es-MX'),
    hora: new Date().toLocaleTimeString('es-MX', {hour:'2-digit',minute:'2-digit'}),
  };

  // Update local state
  mat.stock += STATE.currentMovType === 'entrada' ? qty : -qty;
  STATE.movements.unshift(mov);

  // Send to GAS
  try {
    await callGAS('addMovement', mov);
    showToast(`${STATE.currentMovType === 'entrada' ? 'Entrada' : 'Salida'} registrada ✓`, 'success');
  } catch {
    showToast('Guardado localmente (sin conexión)', '');
  }

  // Clear form
  document.getElementById('mov-material').value = '';
  document.getElementById('mov-qty').value = '';
  document.getElementById('mov-ref').value = '';
  document.getElementById('mov-note').value = '';

  renderDashboard();
  renderInventory();
  renderMovements();
}

function renderMovements() {
  const el = document.getElementById('movement-history-list');
  const movs = STATE.movements.slice(0, 30);
  if (movs.length === 0) {
    el.innerHTML = `<div class="empty-state"><div class="empty-icon">↕️</div><p>Sin movimientos registrados</p></div>`;
    return;
  }
  el.innerHTML = movs.map(m => `
    <div class="mov-item">
      <span class="mov-badge ${m.tipo}">${m.tipo === 'entrada' ? '⬆ ENT' : '⬇ SAL'}</span>
      <div class="mov-info">
        <div class="mov-mat">${m.material}</div>
        <div class="mov-date">${m.fecha} ${m.hora||''} · ${m.ref||'Sin ref.'}</div>
      </div>
      <div class="mov-qty ${m.tipo === 'salida' ? 'neg':''}">
        ${m.tipo === 'entrada' ? '+' : '-'}${m.cantidad}
      </div>
    </div>
  `).join('');
}

function quickMove(id, tipo) {
  showPage('movimientos', document.querySelectorAll('.nav-tab')[2]);
  setMovType(tipo);
  document.getElementById('mov-material').value = id;
}

