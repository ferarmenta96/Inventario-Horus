//  AI ASSISTANT
// ════════════════════════════════════════════
let aiHistory = [];

function buildInventoryContext() {
  const inv = STATE.inventory;
  const mov = STATE.movements.slice(0, 20);
  const lowStock = inv.filter(i => i.stock <= i.minimo);

  return `Eres el asistente de inventario de HORUS, empresa de ingeniería y automatización con IA.
  
INVENTARIO ACTUAL (${inv.length} materiales):
${inv.map(i => `- ${i.tipo}: ${i.nombre} | Calibre: ${i.calibre} | Dim: ${i.dimensiones} | Stock: ${i.stock} ${i.unidad} | Mínimo: ${i.minimo}`).join('\n')}

MATERIALES CON STOCK BAJO (${lowStock.length}):
${lowStock.map(i => `- ${i.nombre}: ${i.stock}/${i.minimo} ${i.unidad}`).join('\n') || 'Ninguno'}

ÚLTIMOS MOVIMIENTOS (20):
${mov.map(m => `- ${m.tipo.toUpperCase()}: ${m.material} | ${m.cantidad} | ${m.fecha} | Ref: ${m.ref||'—'}`).join('\n')}

Responde en español de forma concisa y profesional. Si el usuario pide análisis, sé específico con los datos.`;
}

async function sendAiMessage(text) {
  const input = document.getElementById('ai-input');
  const msg = text || input.value.trim();
  if (!msg) return;

  if (!CONFIG.openaiKey) {
    appendAiMessage('ai', 'Configura tu API Key de OpenAI para usar el asistente.');
    return;
  }

  appendAiMessage('user', msg);
  input.value = '';

  const typingId = appendTyping();
  const sendBtn = document.getElementById('ai-send-btn');
  sendBtn.disabled = true;

  aiHistory.push({ role: 'user', content: msg });

  try {
    const res = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${CONFIG.openaiKey}`,
      },
      body: JSON.stringify({
        model: 'gpt-4o-mini',
        messages: [
          { role: 'system', content: buildInventoryContext() },
          ...aiHistory.slice(-8),
        ],
        max_tokens: 600,
        temperature: 0.7,
      }),
    });

    const data = await res.json();
    removeTyping(typingId);

    if (data.error) throw new Error(data.error.message);

    const reply = data.choices[0].message.content;
    aiHistory.push({ role: 'assistant', content: reply });
    appendAiMessage('ai', reply);
  } catch (e) {
    removeTyping(typingId);
    appendAiMessage('ai', `Error: ${e.message}. Verifica tu API Key de OpenAI.`);
  }

  sendBtn.disabled = false;
}

function sendQuick(text) { sendAiMessage(text); }

function appendAiMessage(role, content) {
  const el = document.getElementById('ai-messages');
  const div = document.createElement('div');
  div.className = `msg-bubble ${role}`;
  div.innerHTML = `
    <div class="msg-sender">${role === 'user' ? '👤 Tú' : '🤖 Asistente HORUS'}</div>
    <div class="msg-content">${content.replace(/\n/g,'<br>')}</div>
  `;
  el.appendChild(div);
  el.scrollTop = el.scrollHeight;
}

function appendTyping() {
  const el = document.getElementById('ai-messages');
  const id = 'typing-' + Date.now();
  const div = document.createElement('div');
  div.className = 'msg-bubble ai';
  div.id = id;
  div.innerHTML = `<div class="msg-sender">🤖 Asistente HORUS</div><div class="msg-content"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
  el.appendChild(div);
  el.scrollTop = el.scrollHeight;
  return id;
}

function removeTyping(id) {
  const el = document.getElementById(id);
  if (el) el.remove();
}

function handleAiKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendAiMessage(); }
}

